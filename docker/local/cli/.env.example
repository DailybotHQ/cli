# Dailybot CLI devcontainer environment variables
#
# Copy this file to `.env` (same directory) and fill in the values you need.
# `.env` is git-ignored. `.env.example` is committed and must NEVER contain real secrets.
#
# These variables are loaded by docker-compose (see ../docker-compose.yaml `env_file`)
# and consumed by the container entrypoint at startup.

# ---------------------------------------------------------------------------
# PyPI publishing (manual release flow)
# ---------------------------------------------------------------------------
# When either token is set, the entrypoint generates `~/.pypirc` (chmod 600)
# inside the container so `twine upload` works without a hand-crafted file.
# Leave both blank if you don't publish from this devcontainer.
#
# Tokens come from:
#   - PyPI:     https://pypi.org/manage/account/token/
#   - TestPyPI: https://test.pypi.org/manage/account/token/
#
# Use the smallest scope possible (project-scoped to `dailybot-cli`).

PYPI_API_TOKEN=
TESTPYPI_API_TOKEN=
